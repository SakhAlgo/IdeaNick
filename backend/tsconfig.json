{
  "ts-node": {
    "files": true,
    "transpileOnly": true,
    "cwd": "."
  },
  "compilerOptions": {
    "allowJs": true,
    // "iterableTypeDeclarations": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": true,
    "isolatedModules": false,
    "lib": ["ES2022"],
    "module": "node16",
    "moduleResolution": "node16",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022"
  },

  "include": ["./src/**/*.ts", "./prisma.config.ts"]
}
