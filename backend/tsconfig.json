{
  "ts-node": {
    "files": true,
    "transpileOnly": true,
    "cwd": "."
  },
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "module": "node16",
    "moduleResolution": "node16",
    "noFallthroughCasesInSwitch": true,
    "noImplicitAny": true,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "sourceRoot": "/",
    "strict": true,
    "target": "ES2022",
    "types": ["node", "jest"]
  },

  "include": ["./src/**/*.ts"]
  // "references": [{ "path": "../shared" }]
}
