{
  "name": "@ideanick/backend",
  "exports": {
    "./src/router": "./src/router/index.ts",
    "./src/router/*": "./src/router/*/index.ts",
    "./src/router/*/input": "./src/router/*/input.ts",
    "./src/utils/can": "./src/utils/can.ts"
  },
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "ts-node-dev --watch ./src/emails/dist,./.env --rs --exit-child ./src/index.ts",
    "build-emails": "rimraf ./src/emails/dist && mkdir ./src/emails/dist && mjml ./src/emails/[!_]*.mjml -o ./src/emails/dist",
    "watch-emails": "mjml -w ./src/emails/[!_]*.mjml -o ./src/emails/dist",
    "copy-emails": "copyfiles -u 1 ./src/emails/dist/*.html ./dist",
    "build-ts": "rimraf ./dist && tsc --build ./tsconfig.json",
    "build": "pnpm build-ts && pnpm build-emails && pnpm copy-emails",
    "start": "node ./dist/index.js",
    "pmd": "prisma migrate dev",
    "pgc": "prisma generate",
    "prepare": "pnpm pgc",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/.eslintcache --ext .ts .",
    "prettify": "prettier --log-level warn --cache --write '{src/**/*,*}.{ts,tsx,js,json,yml,scss}' '!**/{node_modules,dist}/**/*'"
  },
  "dependencies": {
    "@ideanick/shared": "workspace:*",
    "@ideanick/webapp": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@sentry/node": "^10.47.0",
    "@trpc/server": "^11.10.0",
    "add": "^2.0.6",
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "cron": "^4.4.0",
    "debug": "^4.4.3",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "handlebars": "^4.7.8",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.23",
    "mjml": "^4.18.0",
    "node": "^22.22.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "picocolors": "^1.1.1",
    "react-router-dom": "^7.13.0",
    "serialize-error": "8.1.0",
    "superjson": "^2.2.6",
    "triple-beam": "^1.4.1",
    "trpc-ui": "^1.0.15",
    "winston": "^3.19.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@types/cors": "^2.8.19",
    "@types/cron": "^2.4.3",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.2.3",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/triple-beam": "^1.3.5",
    "dotenv": "^17.3.1",
    "eslint-plugin-node": "^11.1.0",
    "prisma": "^7.4.2"
  }
}
