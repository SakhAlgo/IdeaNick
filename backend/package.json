{
  "name": "@ideanick/backend",
  "exports": {
    "./src/router": "./src/router/index.ts",
    "./src/router/createIdea/input": "./src/router/createIdea/input.ts",
    "./src/router/createIdea": "./src/router/createIdea/index.ts",
    "./src/router/getIdea": "./src/router/getIdea/index.ts",
    "./src/router/getIdeas": "./src/router/getIdeas/index.ts",
    "./src/router/signUp/input": "./src/router/signUp/input.ts",
    "./src/router/signUp": "./src/router/signUp/index.ts"
  },
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "ts-node-dev --watch ./.env --rs --exit-child ./src/index.ts",
    "build": "rimraf ./dist && tsc --build ./tsconfig.json",
    "start": "node ./dist/index.js",
    "pmd": "prisma migrate dev",
    "pgc": "prisma generate",
    "prepare": "pnpm pgc",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/.eslintcache --ext .ts .",
    "prettify": "prettier --log-level warn --cache --write '{src/**/*,*}.{ts,tsx,js,json,yml,scss}' '!**/{node_modules,dist}/**/*'"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@trpc/server": "^11.10.0",
    "add": "^2.0.6",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lodash": "^4.17.23",
    "superjson": "^2.2.6",
    "trpc-ui": "^1.0.15",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.2.3",
    "dotenv": "^17.3.1",
    "prisma": "^7.4.2"
  }
}
