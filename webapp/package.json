{
  "name": "@ideanick/webapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "stylecheck": "sass --update -q ./src:./node_modules/.cache/.stylecheckcache",
    "stylelint": "stylelint --cache --cache-location ./node_modules/.cache/.stylelintcache 'src/**/*.scss'",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/.eslintcache --ext .ts .",
    "types": "tsc --noEmit --project ./tsconfig.app.json && tsc --noEmit --project ./tsconfig.node.json",
    "prettify": "prettier --log-level warn --cache --write src/**/*.{ts,tsx,js,json,yml,scss} !**/{node_modules,dist}/**/*"
  },
  "dependencies": {
    "@ideanick/backend": "workspace:*",
    "@ideanick/shared": "workspace:*",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "add": "^2.0.6",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "formik": "^2.4.9",
    "formik-validator-zod": "^2.2.0",
    "include-media": "^2.0.0",
    "js-cookie": "^3.0.5",
    "lodash": "^4.17.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-head": "^3.4.2",
    "react-icons": "^5.6.0",
    "react-infinite-scroller": "^1.2.6",
    "react-router-dom": "^7.13.0",
    "reset-css": "^5.0.2",
    "sass": "^1.97.3",
    "superjson": "^2.2.6",
    "usehooks-ts": "^3.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-infinite-scroller": "^1.2.5",
    "@vitejs/plugin-react": "^5.1.4",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.5.0"
  }
}
